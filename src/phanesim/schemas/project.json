{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project.json",
  "title": "Project",
  "type": "object",
  "required": ["name", "output_path", "sequences"],
  "additionalProperties": false,
  "properties": {
    "name": {"type": "string"},
    "output_path": {"type": "string"},
    "sequences": {
      "type": "array",
      "items": {"$ref": "sequence.json"}
    }
  }
}
