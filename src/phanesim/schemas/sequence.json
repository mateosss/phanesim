{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sequence.json",
  "title": "Sequence",
  "type": "object",
  "required": ["name", "output_path", "camhand_rig", "cam_motions", "hand_motions"],
  "additionalProperties": false,
  "properties": {
    "name": {"type": "string"},
    "output_path": {"type": "string"},
    "camhand_rig": {"$ref": "camhand_rig.json"},
    "cam_motions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Paths to camera motion CSVs, one per camera in camhand_rig order."
    },
    "hand_motions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Paths to hand motion CSVs, one per hand in camhand_rig order."
    }
  }
}
