{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "camhand_rig.json",
  "title": "CameraHandRig",
  "type": "object",
  "required": ["cameras", "hands", "T_c_h"],
  "additionalProperties": false,
  "properties": {
    "cameras": {
      "type": "array",
      "items": {"$ref": "camera.json"}
    },
    "hands": {
      "type": "array",
      "items": {"$ref": "hand.json"}
    },
    "T_c_h": {
      "type": "array",
      "description": "CxH array of transforms. T_c_h[c][h] maps hand-h joints from the hand frame to camera-c frame.",
      "items": {
        "type": "array",
        "items": {"$ref": "defs.json#/$defs/transform"}
      }
    }
  }
}
