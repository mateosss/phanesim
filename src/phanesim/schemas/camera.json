{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "camera.json",
  "title": "Camera",
  "type": "object",
  "required": ["T_b_c", "intrinsics", "resolution", "frequency", "pixel_format", "shutter", "exposure", "gain"],
  "additionalProperties": false,
  "properties": {
    "name": {"type": "string"},
    "T_b_c": {"$ref": "defs.json#/$defs/transform"},
    "intrinsics": {
      "type": "object",
      "required": ["name", "parameters"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "parameters": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        }
      }
    },
    "resolution": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1},
      "minItems": 2,
      "maxItems": 2
    },
    "frequency": {"type": "number", "exclusiveMinimum": 0},
    "pixel_format": {"type": "string"},
    "shutter": {"type": "string", "enum": ["global", "rolling"]},
    "exposure": {"type": "integer"},
    "gain": {"type": "integer"},
    "vignette": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["path"],
          "additionalProperties": false,
          "properties": {"path": {"type": "string"}}
        }
      ]
    },
    "lens_flare": {"type": "boolean"},
    "chromatic_aberration": {"type": "boolean"},
    "motion_blur": {"type": "boolean"}
  }
}
