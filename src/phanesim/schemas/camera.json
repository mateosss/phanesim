{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "camera.json",
  "title": "Camera",
  "type": "object",
  "required": ["T_b_c", "intrinsics", "resolution", "frequency", "pixel_format", "shutter", "exposure", "gain"],
  "additionalProperties": false,
  "properties": {
    "name": {"type": "string"},
    "T_b_c": {"$ref": "defs.json#/$defs/transform"},
    "intrinsics": {
      "type": "object",
      "required": ["name", "parameters"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "parameters": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        }
      }
    },
    "resolution": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1},
      "minItems": 2,
      "maxItems": 2
    },
    "frequency": {"type": "number", "exclusiveMinimum": 0},
    "pixel_format": {"type": "string", "enum": ["RGB24", "MONO8"]},
    "shutter": {"type": "string", "enum": ["global"]},
    "exposure": {"type": "integer"},
    "gain": {"type": "integer"},
    "motion_blur": {"type": "boolean"},
    "ca_factor": {"type": "number", "minimum": 0, "description": "Chromatic Aberration node Factor [0-1+]"},
    "distortion": {"type": "number", "description": "Lens Distortion node Distortion [-1, 1]; negative = pincushion, positive = barrel"},
    "dispersion": {"type": "number", "minimum": 0, "description": "Lens Distortion node Dispersion [0-1]"},
    "lens_scale": {"type": "number", "exclusiveMinimum": 0, "description": "Transform Scale after distortion to crop black borders (e.g. 1.2)"},
    "vignette_factor": {"type": "number", "minimum": 0, "description": "Vignette node Factor [0-1]"},
    "vignette_feather": {"type": "number", "minimum": 0, "description": "Vignette node Feather [0-1]"},
    "noise_std": {"type": "number", "minimum": 0, "description": "Sensor Noise node Luminance Noise [0-1+]; 0 disables the node"},
    "chroma_noise": {"type": "number", "minimum": 0, "description": "Sensor Noise node Chroma Noise [0-1+]"}
  }
}
